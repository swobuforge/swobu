FROM docker.io/library/golang:1.22-bookworm

RUN apt-get update \
  && apt-get install -y --no-install-recommends make git ca-certificates bash curl tar \
  && rm -rf /var/lib/apt/lists/*

ARG GOIMPORTS_VERSION=v0.24.0
ARG GOLANGCI_LINT_VERSION=v1.59.1
ARG AIDER_VERSION=0.86.2

# Preinstall pinned external tooling so containerized verify does not repeatedly
# download/compile ecosystem tools on first command.
RUN GOBIN=/usr/local/bin go install golang.org/x/tools/cmd/goimports@${GOIMPORTS_VERSION} \
  && GOBIN=/usr/local/bin go install github.com/golangci/golangci-lint/cmd/golangci-lint@${GOLANGCI_LINT_VERSION}

# Install deterministic client binaries needed by blocking hermetic client
# integration replay lanes.
ENV PATH="/root/.local/bin:/usr/local/go/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
RUN curl -LsSf https://astral.sh/uv/install.sh | sh \
  && /root/.local/bin/uv tool install --python 3.12 aider-chat@${AIDER_VERSION} \
  && aider --version

WORKDIR /workspace
