.DEFAULT_GOAL := help

# Make target naming law (execution-system contract):
# - names describe intent, not mechanics
# - public API stays small (ROOT_TARGETS)
# - grammar:
#   fmt-* mutates formatting
#   check-* validates without mutation
#   test-* runs tests only
#   verify-* composes merge-safety gates
#   build-* creates tools/artifacts
#   evidence-* manages live evidence artifacts
#   container-* runs a command inside container runtime
# Rule of thumb: target name states the promise, not how it is implemented.

GO ?= go
BIN_DIR := $(CURDIR)/.bin
GOIMPORTS := $(BIN_DIR)/goimports
GOLANGCI_LINT := $(BIN_DIR)/golangci-lint
ROLELINT := $(BIN_DIR)/rolelint
CODELINT := $(BIN_DIR)/codelint
GOIMPORTS_VERSION := v0.24.0
GOLANGCI_LINT_VERSION := v1.59.1
ROOT_TARGETS := setup dev verify verify-concurrency test test-all run evidence-refresh clean
UNIT_TEST_PACKAGES := ./internal/...
CONTRACT_TEST_PACKAGES := ./test/compatibility/surface/...
CONFORMANCE_TEST_PACKAGES := ./test/compatibility/runtime/...
COMPATIBILITY_TEST_PACKAGES := $(CONTRACT_TEST_PACKAGES) $(CONFORMANCE_TEST_PACKAGES)
INTEGRATION_TEST_PACKAGES := ./test/integration/app/... ./test/integration/cli/... ./test/integration/endpointintent/... ./test/integration/httpapi/... ./test/integration/providerports/... ./test/integration/providers/anthropic/... ./test/integration/providers/custom/... ./test/integration/runtime/... ./test/integration/runtimeevidence/...
E2E_TEST_PACKAGES := ./test/e2e/...
MERGE_TEST_PACKAGES := $(UNIT_TEST_PACKAGES) $(CONTRACT_TEST_PACKAGES) $(CONFORMANCE_TEST_PACKAGES) $(INTEGRATION_TEST_PACKAGES)
FULL_TEST_PACKAGES := ./...
RACE_TEST_PACKAGES := $(UNIT_TEST_PACKAGES) ./test/compatibility/surface/cli/... ./test/compatibility/surface/http/... $(CONFORMANCE_TEST_PACKAGES) $(INTEGRATION_TEST_PACKAGES)
GO_TEST_FLAGS ?= -failfast -timeout=5m
GO_TEST_RACE_FLAGS ?= -race -failfast -timeout=10m

.PHONY: help setup dev verify verify-concurrency test test-all run evidence-refresh clean \
	build-tools hooks-install hooks-path task-new run-tui local-ci-fast local-ci local-ci-race check \
	check-required check-doc-refs check-evidence-freshness check-evidence-freshness-warning check-secrets-redaction \
	verify-invariants verify-hermetic verify-hermetic-race verify-evidence-freshness verify-secrets-redaction \
	evidence-refresh-full mine-live-evidence mine-live-evidence-full remind-live-evidence \
	container-verify container-evidence-refresh container-evidence-refresh-full container-evidence-refresh-default \
	verify-hermetic-container mine-live-evidence-container mine-live-evidence-full-container mine-live-evidence-default-container mine-live-evidence-smoke-container \
	fmt fmt-check lint invariants progress-report test-unit test-contract test-conformance test-compatibility test-integration test-integration-providers test-required test-hermetic test-hermetic-client-e2e test-e2e test-race test-race-all \
	rolelint codelint check-artifact-refs artifact-refs doc-refs tools

help: ## Show autogenerated target help
	@awk 'BEGIN {FS = ":.*## "; category = "Targets"; print "Swobu make targets:"} \
		/^##@/ {category = substr($$0, 5); print "\n" category ":"; next} \
		/^[a-zA-Z0-9_.-]+:.*## / {printf "  %-34s %s\n", $$1, $$2}' $(MAKEFILE_LIST)

##@ Public API
setup: hooks-install build-tools ## Install hooks and build local tools

##@ Build
build-tools: $(GOIMPORTS) $(GOLANGCI_LINT) rolelint codelint ## Build/install pinned local developer tools

tools: build-tools

hooks-install:
	git -C .. config core.hooksPath .githooks

hooks-path:
	@git -C .. config --get core.hooksPath || true

task-new:
	@if [ -z "$(GROUP)" ] || [ -z "$(TITLE)" ]; then \
		echo "usage: make task-new GROUP=01-foundations TITLE=short-change-title" >&2; \
		exit 1; \
	fi
	./scripts/create-task-from-template.sh "$(GROUP)" "$(TITLE)"

##@ Public API
dev: fmt check-required ## Run habitual inner loop (format + checks)

run: ## Run swobu TUI
	@if [ ! -t 1 ]; then \
		echo "run target requires interactive terminal; skipping in non-interactive shell"; \
	else \
		$(GO) run ./cmd/swobu; \
	fi

run-tui: run

check-required: fmt-check check-doc-refs check-secrets-redaction check-evidence-freshness-warning ## Run non-mutating required checks

verify: check-required lint test-required ## Run merge-safety gate

verify-concurrency: verify test-race ## Run merge-safety gate with race checks

verify-invariants: check-required

verify-hermetic: verify

verify-hermetic-race: verify-concurrency

local-ci-fast: check-required

local-ci: verify

local-ci-race: verify-concurrency

$(BIN_DIR):
	mkdir -p $(BIN_DIR)

$(GOIMPORTS): | $(BIN_DIR)
	GOBIN=$(BIN_DIR) $(GO) install golang.org/x/tools/cmd/goimports@$(GOIMPORTS_VERSION)

$(GOLANGCI_LINT): | $(BIN_DIR)
	GOBIN=$(BIN_DIR) $(GO) install github.com/golangci/golangci-lint/cmd/golangci-lint@$(GOLANGCI_LINT_VERSION)

rolelint: | $(BIN_DIR)
	$(GO) build -o $(ROLELINT) ./internal/devtools/cmd/rolelint

codelint: | $(BIN_DIR)
	$(GO) build -o $(CODELINT) ./internal/devtools/cmd/codelint

fmt: $(GOIMPORTS)
	@set -eu; \
	files="$$(find cmd internal test -type f -name '*.go' 2>/dev/null)"; \
	if [ -n "$$files" ]; then \
		gofmt -w $$files; \
		$(GOIMPORTS) -w $$files; \
	fi

fmt-check: $(GOIMPORTS)
	@set -eu; \
	files="$$(find cmd internal test -type f -name '*.go' 2>/dev/null)"; \
	if [ -z "$$files" ]; then \
		exit 0; \
	fi; \
	gofmt_out="$$(gofmt -l $$files)"; \
	goimports_out="$$( $(GOIMPORTS) -l $$files )"; \
	if [ -n "$$gofmt_out$$goimports_out" ]; then \
		printf 'Files need formatting:\n%s\n%s\n' "$$gofmt_out" "$$goimports_out"; \
		exit 1; \
	fi

lint: $(GOLANGCI_LINT) rolelint codelint
	CGO_ENABLED=0 $(GO) build ./...
	CGO_ENABLED=0 $(GOLANGCI_LINT) run ./...
	$(ROLELINT) ./...
	$(CODELINT) ./...
	./scripts/check-artifact-policy.sh

invariants:
	$(GO) test ./test/integration/invariants/...

##@ Check
check-doc-refs: ## Validate docs and artifact reference policies
	./scripts/check-doc-policy.sh
	./scripts/check-artifact-policy.sh

doc-refs: check-doc-refs

check-evidence-freshness: ## Fail when live evidence is stale
	./scripts/check-evidence-freshness.sh

verify-evidence-freshness: check-evidence-freshness

check-secrets-redaction: ## Fail on evidence secret leakage patterns
	./scripts/check-secret-redaction.sh

verify-secrets-redaction: check-secrets-redaction

check-evidence-freshness-warning: ## Warn when live evidence is stale
	@./scripts/check-evidence-freshness.sh || { \
		echo "warning: live evidence is stale; run 'make evidence-refresh' explicitly to refresh artifacts"; \
	}

remind-live-evidence: check-evidence-freshness-warning

progress-report:
	$(GO) run ./internal/devtools/cmd/progressreport --root .. --tags P0

check-artifact-refs:
	./scripts/check-artifact-policy.sh

artifact-refs: check-artifact-refs

##@ Evidence
evidence-refresh: ## Refresh live evidence artifacts (manual, non-blocking)
	./scripts/evidence-refresh-live.sh

evidence-refresh-full:
	./scripts/evidence-refresh-live.sh -cases test/fixtures/live_matrix/scenario_cases.full.json

mine-live-evidence: evidence-refresh

mine-live-evidence-full: evidence-refresh-full

##@ Container
container-verify: ## Run verify inside podman/docker container
	@./scripts/container-run-hermetic.sh "make -f Makefile.core verify" || { \
		echo "warning: container verify failed in this environment; host verify remains authoritative"; \
	}

container-evidence-refresh: ## Run evidence-refresh inside podman/docker container
	./scripts/container-run-live-evidence.sh "make -f Makefile.core evidence-refresh"

container-evidence-refresh-full: ## Run evidence-refresh-full inside podman/docker container
	./scripts/container-run-live-evidence.sh "make -f Makefile.core evidence-refresh-full"

container-evidence-refresh-default: ## Run default evidence lane inside podman/docker container
	./scripts/container-run-live-evidence.sh "./scripts/evidence-refresh-live.sh -cases test/fixtures/live_matrix/scenario_cases.smoke.json"

verify-hermetic-container: container-verify

mine-live-evidence-container: container-evidence-refresh

mine-live-evidence-full-container: container-evidence-refresh-full

mine-live-evidence-default-container: container-evidence-refresh-default

mine-live-evidence-smoke-container: container-evidence-refresh-default

##@ Public API
test: test-required ## Run required deterministic test bundle

##@ Test Lanes
test-unit: ## Run unit tests
	CGO_ENABLED=0 $(GO) test $(GO_TEST_FLAGS) $(UNIT_TEST_PACKAGES)

test-contract: ## Run compatibility surface contract tests
	CGO_ENABLED=0 $(GO) test $(GO_TEST_FLAGS) $(CONTRACT_TEST_PACKAGES)

test-conformance: ## Run compatibility runtime conformance tests
	CGO_ENABLED=0 $(GO) test $(GO_TEST_FLAGS) $(CONFORMANCE_TEST_PACKAGES)

test-compatibility:
	$(MAKE) -f Makefile.core test-contract
	$(MAKE) -f Makefile.core test-conformance

test-integration: ## Run deterministic integration suite
	CGO_ENABLED=0 $(GO) test $(GO_TEST_FLAGS) $(INTEGRATION_TEST_PACKAGES)

test-integration-providers: ## Run deterministic provider integration checks
	CGO_ENABLED=0 $(GO) test $(GO_TEST_FLAGS) ./test/integration/providers -run 'TestLiveMatrixOfflineDecode_FailsOnTranscriptDrift|TestProviderCatalog_DeclaredProtocolsAndModelsAreExecutable'

test-required: test-unit test-contract test-conformance test-integration test-integration-providers test-hermetic-client-e2e ## Run required deterministic test bundle

test-hermetic: test-required

test-hermetic-client-e2e:
ifeq ($(SWOBU_HERMETIC_CONTAINER),1)
	CGO_ENABLED=0 $(GO) test $(GO_TEST_FLAGS) ./test/e2e -run 'TestHermeticClientConfigReplay_Aider'
else
	./scripts/container-run-hermetic.sh "go test $(GO_TEST_FLAGS) ./test/e2e -run 'TestHermeticClientConfigReplay_Aider'"
endif

test-e2e: ## Run full e2e suite
	CGO_ENABLED=0 $(GO) test $(GO_TEST_FLAGS) $(E2E_TEST_PACKAGES)

test-all: ## Run full Go test suite
	CGO_ENABLED=0 $(GO) test $(GO_TEST_FLAGS) $(FULL_TEST_PACKAGES)

test-race:
	CGO_ENABLED=1 $(GO) test $(GO_TEST_RACE_FLAGS) $(RACE_TEST_PACKAGES)

test-race-all:
	CGO_ENABLED=1 $(GO) test $(GO_TEST_RACE_FLAGS) $(RACE_TEST_PACKAGES)

check: verify ## Alias for verify

clean: ## Remove repo-local tool binaries
	rm -rf $(BIN_DIR)
